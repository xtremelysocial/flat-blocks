{
	"$schema": "https://json.schemastore.org/theme-v1.json",
	"version": 2,
	"settings": {
		"custom": {
			"alignment": {
				"alignedMaxWidth": "50%"
			},
			"margin": {
				"baseline": "1rem /*use gap instead*/",
				"horizontal": "2rem /*use gap instead*/",
				"vertical": "2rem /*use gap instead*/"
			},
			"gap": {
				"baseline": "min(18px, 3vw) /* e.g. headings */",
				"horizontal": "min(36px, 5vw) /* e.g. columns */",
				"vertical": "min(36px, 5vw)"
			},
			"navigation": {
				"submenu": {
					"border": {
						"color": "var(--wp--preset--color--primary)",
						"radius": "var(--wp--custom--form--border--radius)",
						"style": "var(--wp--custom--form--border--style)",
						"width": "var(--wp--custom--form--border--width)"
					},
					"color": {
						"background": "var(--wp--custom--color--background)",
						"text": "var(--wp--preset--color--foreground)"
					}
				}
			},
			"body": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body-font)",
					"fontWeight": "300",
					"fontSize": "1rem",
					"lineHeight": 1.4
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading-font)",
					"fontWeight": "300",
					"lineHeight": 1.125
				}
			},
			"border": {
				"radius": "4px",
				"style": "solid",
				"none": "0px",
				"thin": "1px",
				"normal": "3px",
				"thick": "6px"
			},
			"list": {
				"spacing": {
					"padding": {
						"left": "var(--wp--custom--gap--horizontal)"
					}
				}
			},
			"paragraph": {
				"dropcap": {
					"margin": ".1em .1em 0 0",
					"typography": {
						"fontSize": "var(--wp--preset--font-size--huge)",
						"fontWeight": "normal"
					}
				}
			},
			"separator": {
				"opacity": 1,
				"margin": "var(--wp--custom--gap-baseline) auto",
				"width": "150px"
			},
			"button": {
				"border": {
					"color": "var(--wp--preset--color--offwhite)",
					"radius": "var(--wp--custom--border--radius)",
					"style": "var(--wp--custom--border--style)",
					"width": "var(--wp--custom--border--normal)"
				},
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--offwhite)"
				},
				"hover": {
					"color": {
						"text": "var(--wp--preset--color--offwhite)",
						"background": "#3A3A3A"
					},
					"border": {
						"color": "var(--wp--preset--color--secondary)"
					}
				},
				"spacing": {
					"padding": {
						"top": "0.667rem",
						"bottom": "0.667rem",
						"left": "1.333rem",
						"right": "1.333rem"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--custom--body--typography--font-family)",
					"fontSize": "var(--wp--custom--body--typography--font-size)",
					"fontWeight": "bolder",
					"lineHeight": "var(--wp--custom--body--typography--line-height)"
				}
			},
			"code": {
				"typography": {
					"fontFamily": "monospace"
				}
			},
			"color": {
				"header": "var(--wp--preset--color--offwhite)",
				"header-alt": "var(--wp--preset--color--lightgray)",
				"header-text": "var(--wp--preset--color--notquiteblack)",
				"header-link": "var(--wp--preset--color--lightgreen)",
				"title": "var(--wp--preset--color--lightgreen)",
				"title-alt": "var(--wp--preset--color--darkgreen)",
				"title-text": "var(--wp--preset--color--offwhite)",
				"title-link": "var(--wp--preset--color--offwhite)",
				"primary": "var(--wp--preset--color--lightgreen)",
				"primary-alt": "var(--wp--preset--color--darkgreen)",
				"primary-text": "var(--wp--preset--color--offwhite)",
				"primary-link": "var(--wp--preset--color--offwhite)",
				"secondary": "var(--wp--preset--color--midnightblue)",
				"secondary-alt": "var(--wp--preset--color--darkmidnightblue)",
				"secondary-text": "var(--wp--preset--color--offwhite)",
				"secondary-link": "var(--wp--preset--color--offwhite)",
				"tertiary": "var(--wp--preset--color--orange)",
				"tertiary-alt": "var(--wp--preset--color--darkorange)",
				"tertiary-text": "var(--wp--preset--color--white)",
				"tertiary-link": "var(--wp--preset--color--white)",
				"foreground": "var(--wp--preset--color--notquiteblack)",
				"background": "var(--wp--preset--color--offwhite)",
				"border": "var(--wp--preset--color--gray)",
				"footer": "var(--wp--preset--color--almostblack)",
				"footer-alt": "var(--wp--preset--color--notquiteblack)",
				"footer-text": "var(--wp--preset--color--lightgray)",
				"footer-link": "var(--wp--preset--color--lightgreen)"
			},
