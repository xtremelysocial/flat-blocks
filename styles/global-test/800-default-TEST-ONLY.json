{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Default - TEST ONLY",
	"settings": {
		"custom": {
			"shadow": "var(--wp--preset--shadow--natural)"
		}
	},
	"styles": {
		"css": "@media (prefers-color-scheme: dark) { body { color-scheme: dark light; --wp--preset--color--base: var(--wp--preset--color--not-quite-black); --wp--preset--color--contrast: var(--wp--preset--color--off-white); --wp--preset--color--neutral: var(--wp--preset--color--gray); --wp--preset--color--neutral-alt: var(--wp--preset--color--very-dark-gray); } }",
		"blocks": {
			"core/heading": {
				"color": {
					"text": "var:preset|color|tertiary"
				}
			},
			"core/button": {
				"typography": {
					"fontFamily": "var:preset|font-family|monospace",
					"fontSize": "var(--wp--preset--font-size--normal)",
					"fontWeight": "700"
				},
				"border": {
					"radius": "9999px"
				}
			},
			"core/navigation": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			}
		},
		"elements": {
			"button": {
				"border": {
					"radius": "9999px"		
				}
			},
			"link": {
				"typography": {
					"textDecoration": "underline"
				}
			}
		}
	}
}